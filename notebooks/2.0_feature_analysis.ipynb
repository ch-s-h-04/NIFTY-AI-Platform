 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Phase 2: NIFTY-50 Feature Engineering & Analysis\n",
    "This notebook covers the validation, visualization, and collinearity checking of technical, momentum, risk, and index features engineered for the NIFTY-50 dataset. \n",
    "It addresses all Phase 2 requirements:\n",
    "1. **Feature Construction**: SMA, EMA, RSI, MACD, Bollinger Bands, ROC, ATR, Volatility, systematic Beta, and index returns.\n",
    "2. **Visualization**: Technical indicator overlays, distributions, and correlation heatmap.\n",
    "3. **Collinearity Analysis**: Correlation heatmap identifying high-correlation feature pairs.\n",
    "4. **Leakage Validation Check**: Empirical proof of zero lookahead bias by perturbing future data."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import sys\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Append parent directory to sys.path so 'src' is importable\n",
    "sys.path.append(\"..\")\n",
    "\n",
    "from src.config import SYMBOLS, SECTOR_MAP\n",
    "from src.features import build_feature_matrix, generate_stock_features\n",
    "from src.data_loader import load_index_data\n",
    "\n",
    "# Set default plot styles\n",
    "plt.style.use(\"seaborn-v0_8-whitegrid\" if \"seaborn-v0_8-whitegrid\" in plt.style.available else \"ggplot\")\n",
    "plt.rcParams[\"figure.figsize\"] = (12, 6)\n",
    "plt.rcParams[\"axes.grid\"] = True"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Feature Matrix Construction & Overview\n",
    "We build the feature matrix for a subset of major tickers (INFY, TCS, RELIANCE, HDFCBANK, SBIN) from 2010 to 2021 to examine the dimensions, metrics, and missing values."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "test_symbols = ['INFY', 'TCS', 'RELIANCE', 'HDFCBANK', 'SBIN']\n",
    "feature_df = build_feature_matrix(test_symbols, start_date=\"2010-01-01\", end_date=\"2021-04-30\")\n",
    "\n",
    "print(\"=== FEATURE MATRIX SUMMARY ===\")\n",
    "print(f\"Shape of feature matrix: {feature_df.shape}\")\n",
    "print(f\"Total features computed: {len(feature_df.columns)}\")\n",
    "\n",
    "# Check missing value statistics\n",
    "print(\"\\n=== MISSING VALUES PERCENTAGES ===\")\n",
    "missing_pcts = (feature_df.isnull().sum() / len(feature_df)) * 100\n",
    "print(missing_pcts.sort_values(ascending=False).head(10))\n",
    "print(\"\\nNote: The rolling Beta (60-day window) represents the only column containing initial missing values, which is mathematically expected.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Visualizing Technical Indicators\n",
    "We visualize the engineered Bollinger Bands, SMA 20, and RSI for INFY over a two-year subset (2019-2020) to check indicator behavior."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Extract INFY features\n",
    "df_infy = feature_df[[c for c in feature_df.columns if 'INFY_' in c]].copy()\n",
    "df_infy.columns = [c.replace('INFY_', '') for c in df_infy.columns]\n",
    "\n",
    "# Filter dates\n",
    "plot_df = df_infy.loc['2019-01-01':'2020-12-31']\n",
    "\n",
    "# Plot Close and Bollinger Bands\n",
    "plt.figure(figsize=(14, 7))\n",
    "plt.plot(plot_df.index, plot_df['Close'], label='Close Price', color='darkblue', linewidth=1.5)\n",
    "plt.plot(plot_df.index, plot_df['SMA_20'], label='SMA 20', color='orange', linestyle='--')\n",
    "plt.plot(plot_df.index, plot_df['BB_upper'], label='Bollinger Upper', color='crimson', alpha=0.6, linewidth=1.0)\n",
    "plt.plot(plot_df.index, plot_df['BB_lower'], label='Bollinger Lower', color='crimson', alpha=0.6, linewidth=1.0)\n",
    "plt.fill_between(plot_df.index, plot_df['BB_lower'], plot_df['BB_upper'], color='crimson', alpha=0.04)\n",
    "plt.title(\"INFY Close Price with Bollinger Bands & SMA 20 (2019-2020)\")\n",
    "plt.ylabel(\"Price (INR)\")\n",
    "plt.legend()\n",
    "plt.show()\n",
    "\n",
    "# Plot RSI\n",
    "fig, ax = plt.subplots(figsize=(14, 3.5))\n",
    "ax.plot(plot_df.index, plot_df['RSI_14'], color='purple', label='RSI 14-day')\n",
    "ax.axhline(70, color='red', linestyle='--', alpha=0.5, label='Overbought (70)')\n",
    "ax.axhline(30, color='green', linestyle='--', alpha=0.5, label='Oversold (30)')\n",
    "ax.set_ylabel(\"RSI Level\")\n",
    "ax.set_ylim(10, 90)\n",
    "plt.title(\"INFY RSI (14-day Window)\")\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Feature Distributions\n",
    "We plot the distribution curves for RSI, Volatility, ROC, and systematic Beta to confirm statistical characteristics."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
    "\n",
    "sns.histplot(df_infy['RSI_14'].dropna(), kde=True, ax=axes[0,0], color='purple', stat='density')\n",
    "axes[0,0].set_title(\"RSI 14 Distribution\")\n",
    "\n",
    "sns.histplot(df_infy['Volatility_20'].dropna(), kde=True, ax=axes[0,1], color='orange', stat='density')\n",
    "axes[0,1].set_title(\"Annualized 20-day Volatility Distribution\")\n",
    "\n",
    "sns.histplot(df_infy['ROC_21'].dropna(), kde=True, ax=axes[1,0], color='teal', stat='density')\n",
    "axes[1,0].set_title(\"21-day Rate of Change (ROC) Distribution\")\n",
    "\n",
    "sns.histplot(df_infy['Beta_60'].dropna(), kde=True, ax=axes[1,1], color='brown', stat='density')\n",
    "axes[1,1].set_title(\"Systematic Beta (60-day) Distribution\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Collinearity & Correlation Analysis\n",
    "We compute a Pearson correlation heatmap across all features calculated for INFY to locate highly correlated variable groups (collinearity) that could affect standard regression models."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "plt.figure(figsize=(14, 12))\n",
    "sns.heatmap(df_infy.corr(), cmap='coolwarm', vmin=-1, vmax=1)\n",
    "plt.title(\"Returns Correlation Matrix Heatmap (INFY Features)\")\n",
    "plt.show()\n",
    "\n",
    "# List top correlated features (excluding identical mappings)\n",
    "corr_matrix = df_infy.corr().abs()\n",
    "upper_tri = corr_matrix.where(np.triu(np.ones(corr_matrix.shape), k=1).astype(bool))\n",
    "flat_corr = upper_tri.stack().sort_values(ascending=False)\n",
    "print(\"=== HIGHLY COLLINEAR FEATURE PAIRS (TOP 10) ===\")\n",
    "print(flat_corr.head(10))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Leakage Validation Check\n",
    "We run an empirical test for lookahead bias by perturbing a future price entry (setting price at $t+10$ to 99999.0) and confirming that the historical features calculated at day $s \\le t$ remain identical. This proves zero lookahead leakage."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load baseline indices and files\n",
    "nifty_df = load_index_data(\"NIFTY 50\")\n",
    "nifty_df['Market_Ret'] = np.log(nifty_df['Close'] / nifty_df['Close'].shift(1))\n",
    "nifty_df['Market_ROC_21'] = nifty_df['Close'] / nifty_df['Close'].shift(21) - 1.0\n",
    "nifty_df['Market_Mom_5'] = nifty_df['Close'] / nifty_df['Close'].shift(5) - 1.0\n",
    "nifty_df['Market_Mom_21'] = nifty_df['Close'] / nifty_df['Close'].shift(21) - 1.0\n",
    "\n",
    "vix_df = load_index_data(\"INDIA VIX\")\n",
    "if not vix_df.empty:\n",
    "    vix_df['VIX_ROC_5'] = vix_df['Close'] / vix_df['Close'].shift(5) - 1.0\n",
    "\n",
    "sector_returns = {\n",
    "    'NIFTY 50': pd.Series(nifty_df['Market_Ret'].values, index=nifty_df['Date']),\n",
    "    'NIFTY 50_Mom_5': pd.Series(nifty_df['Market_Mom_5'].values, index=nifty_df['Date']),\n",
    "    'NIFTY 50_Mom_21': pd.Series(nifty_df['Market_Mom_21'].values, index=nifty_df['Date']),\n",
    "}\n",
    "\n",
    "symbol = \"INFY\"\n",
    "baseline_feat = generate_stock_features(symbol, nifty_df, vix_df, sector_returns)\n",
    "\n",
    "# Set pivot target date t\n",
    "target_idx = len(baseline_feat) // 2\n",
    "target_date = baseline_feat.iloc[target_idx]['Date']\n",
    "pre_features_baseline = baseline_feat.iloc[:target_idx + 1].copy()\n",
    "\n",
    "# Future index to modify (t + 10)\n",
    "future_idx = target_idx + 10\n",
    "future_date = baseline_feat.iloc[future_idx]['Date']\n",
    "\n",
    "# Mock load_stock_data to inject anomaly in the future\n",
    "import src.data_loader\n",
    "original_load_stock_data = src.data_loader.load_stock_data\n",
    "\n",
    "def mock_load_stock_data(sym):\n",
    "    df = original_load_stock_data(sym)\n",
    "    if sym == symbol and not df.empty:\n",
    "        df = df.copy()\n",
    "        df.loc[df['Date'] == future_date, 'Close'] = 99999.0\n",
    "        df.loc[df['Date'] == future_date, 'High'] = 99999.0\n",
    "        df.loc[df['Date'] == future_date, 'Low'] = 99999.0\n",
    "    return df\n",
    "\n",
    "src.data_loader.load_stock_data = mock_load_stock_data\n",
    "modified_feat = generate_stock_features(symbol, nifty_df, vix_df, sector_returns)\n",
    "src.data_loader.load_stock_data = original_load_stock_data  # Restore original\n",
    "\n",
    "# Compare pre-t features\n",
    "pre_features_modified = modified_feat.iloc[:target_idx + 1].copy()\n",
    "feature_columns = [c for c in baseline_feat.columns if c not in ['Date', 'Close', 'Volume']]\n",
    "\n",
    "leakage_detected = False\n",
    "for col in feature_columns:\n",
    "    diff = (pre_features_baseline[col] - pre_features_modified[col]).abs().sum()\n",
    "    if diff > 1e-5:\n",
    "        print(f"LEAKAGE DETECTED in: {col}! Cumulative Difference: {diff}")\n",
    "        leakage_detected = True\n",
    "\n",
    "if not leakage_detected:\n",
    "    print(\"\\n=== LEAKAGE CHECK RESULT ===\")\n",
    "    print(\"SUCCESS: Zero lookahead bias detected. Past features are independent of future data.\")\n",
    "else:\n",
    "    print(\"\\n=== LEAKAGE CHECK RESULT ===\")\n",
    "    print(\"FAILURE: Lookahead leakage detected in one or more features.\")"
   ]
  }
 ],
